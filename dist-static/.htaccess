# Routage SPA pour Hostinger / Apache
# Si vous déployez sur Netlify/Vercel, le fichier _redirects (déjà présent dans public/) suffit.
# Sur Hostinger (Apache), ce fichier .htaccess est obligatoire pour que les routes /formations, /admissions, etc.
# fonctionnent quand l'utilisateur recharge la page ou ouvre un lien direct.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si la requête correspond à un fichier ou dossier existant, on le sert directement
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sinon, on redirige tout vers index.html (routage SPA TanStack)
  RewriteRule ^ index.html [L]
</IfModule>

# Compression Gzip pour accélérer le chargement
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache des assets statiques (1 an pour les images, 1 mois pour CSS/JS)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Sécurité — empêcher l'affichage du contenu des dossiers
Options -Indexes
